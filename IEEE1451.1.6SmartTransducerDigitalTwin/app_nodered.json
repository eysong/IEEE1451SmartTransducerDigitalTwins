            ]
        ]
    },
    {
        "id": "582501f665471b3d",
        "type": "function",
        "z": "dbbfb8a1ee1c3552",
        "name": "update graph",
        "func": "let start = flow.get(\"start\") || Date.now();\nflow.set(\"start\", start);\n\nlet elapsed = ((Date.now() - start) / 1000).toFixed(1);\n\nlet chartData = flow.get(\"chartData\") || {};\n\nchartData.temperature = chartData.temperature || [];\nchartData.upper_threshold = chartData.upper_threshold || [];\nchartData.lower_threshold = chartData.lower_threshold || [];\nchartData.labels = chartData.labels || [];\n\nchartData.temperature.push(parseFloat(msg.tempVal));\nchartData.upper_threshold.push(27.0)\nchartData.lower_threshold.push(25.0)\nchartData.labels.push(elapsed + \"s\");\n\nflow.set(\"chartData\", chartData);\n\nmsg.payload = [\n    {\n        series: [\"temperature\", \"upper threshold\", \"lower threshold\"],\n        data: [chartData.temperature, chartData.upper_threshold, chartData.lower_threshold],\n        labels: chartData.labels\n    }\n];\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 1330,
        "y": 740,
        "wires": [
            [
                "e9724093feb24fc3"
            ]
        ]
    },
