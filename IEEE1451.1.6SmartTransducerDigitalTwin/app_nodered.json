    {
        "id": "7f79d7b26ffb16fa",
        "type": "function",
        "z": "dbbfb8a1ee1c3552",
        "name": "sensorreq report pub thru",
        "func": "// sensorreq = { # sensor data request\n//   \"netSvcType\" :  2, # transducer access services\n//   \"setSvcId\" : 1, # read from channel of TIM\n//   \"msgType\" : 1, # command\n//   \"msgLength\" : 61, # bytes\n//   \"appId\" : appId,\n//   \"ncapId\" : sensorId,\n//   \"timId\" : rpiId,\n//   \"channelId\" : 1,\n//   \"samplingMode\" : 5, # continuous\n//   \"timeout\" : 60,\n// }\n\nvar buf = new Buffer(65);\nbuf[0] = 2; // netSvcType\nbuf[1] = 1; // netSvcId\nbuf[2] = 1; // msgType\nbuf[3] = 61; // msgLength\nbuf[4] = 0x04; // UUID appId 0\nbuf[5] = 0x10; // 1\nbuf[6] = 0x00; // 2\nbuf[7] = 0x00; // 3\nbuf[8] = 0x27; // 4\nbuf[9] = 0x00; // 5\nbuf[10] = 0x00; // 6\nbuf[11] = 0x4D; // 7\nbuf[12] = 0x00; // 8\nbuf[13] = 0x00; // 9\nbuf[14] = 0x00; // 10\nbuf[15] = 0x07; // 11\nbuf[16] = 0xE9; // 12\nbuf[17] = 0x00; // 13\nbuf[18] = 0x00; // 14\nbuf[19] = 0x00; // 15\nbuf[20] = 0x04; // UUID ncapId 0\nbuf[21] = 0x10; // 1\nbuf[22] = 0x00; // 2\nbuf[23] = 0x00; // 3\nbuf[24] = 0x27; // 4\nbuf[25] = 0x00; // 5\nbuf[26] = 0x00; // 6\nbuf[27] = 0x4D; // 7\nbuf[28] = 0x00; // 8\nbuf[29] = 0x00; // 9\nbuf[30] = 0x02; // 10\nbuf[31] = 0x07; // 11\nbuf[32] = 0xE9; // 12\nbuf[33] = 0x00; // 13\nbuf[34] = 0x00; // 14\nbuf[35] = 0x00; // 15\nbuf[36] = 0x04; // UUID timId 0\nbuf[37] = 0x10; // 1\nbuf[38] = 0x00; // 2\nbuf[39] = 0x00; // 3\nbuf[40] = 0x27; // 4\nbuf[41] = 0x00; // 5\nbuf[42] = 0x00; // 6\nbuf[43] = 0x4D; // 7\nbuf[44] = 0x00; // 8\nbuf[45] = 0x00; // 9\nbuf[46] = 0x01; // 10\nbuf[47] = 0x07; // 11\nbuf[48] = 0xE9; // 12\nbuf[49] = 0x00; // 13\nbuf[50] = 0x00; // 14\nbuf[51] = 0x00; // 15\nbuf[52] = 1; // channelId 0\nbuf[53] = 0; // 1\nbuf[54] = 5; // samplingMode 0\nbuf[55] = 0x00 // timeout 0\nbuf[56] = 0x3C // 1\nbuf[57] = 0; // 2\nbuf[58] = 0; // 3\nbuf[59] = 0; // 4\nbuf[60] = 0; // 5\nbuf[61] = 0; // 6\nbuf[62] = 0; // 7\nbuf[63] = 0; // 8\nbuf[64] = 0; // 9\n\nmsg.payload = buf;\nmsg.report = \"<br>Smart sensor request published.\"\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 810,
        "y": 460,
